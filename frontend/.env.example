# Base URL of the Arena AI Platform API.
# In dev, the Vite proxy (vite.config.js) forwards /api to VITE_API_PROXY_TARGET,
# so you can usually leave VITE_API_URL unset locally and it will default to /api.
# In production, point this at your deployed API's public URL, e.g.:
# VITE_API_URL=https://api.your-domain.com/api
VITE_API_URL=
